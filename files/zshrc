# ── Git workflow aliases and functions ─────────────────────────────────────────

# Helper: detect default branch (master or main)
_git_default_branch() {
  if git show-ref --verify --quiet refs/heads/main; then
    echo "main"
  else
    echo "master"
  fi
}

# Sync fork via gh repo sync (auto-detects master/main)
ghsync() {
  local branch=$(_git_default_branch)
  git checkout "$branch" && \
    gh repo sync mpagot/$(basename $(git rev-parse --show-toplevel)) -b "$branch" && \
    git pull
}

# Sync fork via fetch upstream (auto-detects master/main)
gfup() {
  local branch=$(_git_default_branch)
  git checkout "$branch" && \
    git fetch upstream && \
    git merge "upstream/$branch" && \
    git push && \
    git pull
}

# Checkout branch with fzf
gcof() {
  local BRANCH="$(git for-each-ref --sort=-committerdate refs/heads/ --format='%(committerdate:iso8601) %(refname:short)' | fzf | cut -d ' ' -f 4)"
  git checkout "$BRANCH"
}

# Git add with fzf (multi-select)
gaf() {
  git add $(git status | grep 'modified:' | sed 's/.*modified://' | fzf -m)
}

# Git diff with fzf (multi-select)
gdf() {
  git diff $(git status | grep 'modified:' | sed 's/.*modified://' | fzf -m)
}

# Git push set-upstream to current branch
alias gpsu='git push --set-upstream origin $(git rev-parse --abbrev-ref HEAD)'

# Git push force-with-lease to current branch
alias gpfl='git push --force-with-lease origin $(git rev-parse --abbrev-ref HEAD)'

# Look up your PR on the upstream repo for the current branch
gh_pr() {
  local MYGH_UP="$(git config --get remote.upstream.url)"
  echo "MYGH_UP : ${MYGH_UP}"
  local MYGH_BRANCH="$(git rev-parse --abbrev-ref HEAD)"
  echo "MYGH_BRANCH : ${MYGH_BRANCH}"
  local MYGH_PR="$(GH_PAGER= gh pr -R ${MYGH_UP} --json 'number' -q '.[0].number' list -A mpagot -H ${MYGH_BRANCH} -s all)"
  echo "This is PR: ${MYGH_PR}"
  [[ -z "${MYGH_PR}" ]] && echo "No PR!!!"
  GH_PAGER= gh pr -R ${MYGH_UP} view $1 ${MYGH_PR}
}


# ~/.zshrc — devenv shell configuration

# ── History ────────────────────────────────────────────────────────────────────
HISTFILE=~/.zsh_history
HISTSIZE=100000
SAVEHIST=100000
setopt HIST_IGNORE_DUPS       # don't store consecutive duplicates
setopt HIST_IGNORE_SPACE      # don't store lines starting with a space
setopt SHARE_HISTORY          # share history across sessions (atuin takes over live sync)
setopt EXTENDED_HISTORY       # save timestamp + duration

# ── Completion ─────────────────────────────────────────────────────────────────
autoload -Uz compinit
compinit -d ~/.cache/zcompdump

# Case-insensitive tab completion
zstyle ':completion:*' matcher-list 'm:{a-z}={A-Z}'
# Menu-style selection
zstyle ':completion:*' menu select
# Group completions by type
zstyle ':completion:*' group-name ''
zstyle ':completion:*:descriptions' format '%B%d%b'
# Use colours in completion list
zstyle ':completion:*:default' list-colors "${(s.:.)LS_COLORS}"

# gh completions
if command -v gh &>/dev/null; then
  eval "$(gh completion -s zsh)"
fi

# uv completions
if command -v uv &>/dev/null; then
  eval "$(uv generate-shell-completion zsh)"
fi

# ── Key bindings ───────────────────────────────────────────────────────────────
bindkey -e                        # emacs key bindings (Ctrl-A/E, etc.)
bindkey '^[[A' history-search-backward   # Up arrow: history prefix search
bindkey '^[[B' history-search-forward    # Down arrow

# ── Aliases: eza (ls replacement) ─────────────────────────────────────────────
alias ll="eza -a --icons --group-directories-first --time-style=long-iso --octal-permissions --color=always -lhg -s modified --tree --level 1"


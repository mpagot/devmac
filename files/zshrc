# ── Environment ────────────────────────────────────────────────────────────────
export EDITOR='vim'
export PAGER='less'
export LESS='-RFX'

# Prefer XDG dirs
export XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
export XDG_DATA_HOME="${XDG_DATA_HOME:-$HOME/.local/share}"
export XDG_CACHE_HOME="${XDG_CACHE_HOME:-$HOME/.cache}"

# ── PATH additions ─────────────────────────────────────────────────────────────
# User-local binaries (pip install --user, etc.)
export PATH="$HOME/.local/bin:$PATH"
# ~/bin — standalone LSP/tool binaries (marksman, vale-ls, perlnavigator, terraform-ls, codelldb, …)
export PATH="$HOME/bin:$PATH"
# Cargo — rust-analyzer and other Rust-installed tools
export PATH="$HOME/.cargo/bin:$PATH"
# asdf shims — nodejs LSPs (bash-language-server, yaml-language-server, prettier, ansible-language-server)
export PATH="${ASDF_DATA_DIR:-$HOME/.asdf}/shims:$PATH"

# ── Tool initialisation (ORDER MATTERS: fzf → zoxide → atuin → starship) ──────

# 1. fzf — fuzzy finder shell integration
if command -v fzf &>/dev/null; then
  source <(fzf --zsh)
fi

# 2. zoxide — smart cd (provides z and zi commands)
if command -v zoxide &>/dev/null; then
  eval "$(zoxide init zsh)"
fi

# 3. atuin — shell history sync + search (replaces Ctrl-R)
if command -v atuin &>/dev/null; then
  eval "$(atuin init zsh)"
fi

# 4. starship — prompt (must be last)
if command -v starship &>/dev/null; then
  eval "$(starship init zsh)"
fi
